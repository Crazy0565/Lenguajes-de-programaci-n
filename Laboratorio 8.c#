using System;

class Program
{
    static void Main()
    {
        try
        {
            Console.Write("Ingrese número de historia clínica: ");
            int numero = int.Parse(Console.ReadLine());

            Console.WriteLine("Historia #" + numero + " registrada correctamente.");
        }
        catch
        {
            Console.WriteLine("Error: Solo se permiten números.");
        }
    }
}
