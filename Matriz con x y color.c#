using System;

class Program
{
    static void Main()
    {
        int filas = 6;
        int columnas = 6;
        string[,] matriz = new string[filas, columnas];

        for (int i = 0; i < filas; i++)
        {
            for (int j = 0; j < columnas; j++)
            {
                matriz[i, j] = " ";
            }
        }
            for (int j = 0; j < columnas; j++)
            {
                matriz[0, j] = "=";
                matriz[5, j] = "=";
            }

            for (int i = 1; i < filas - 1; i++)
            {
                matriz[i, 0] = "=";
                matriz[i, 5] = "=";
            }
            
        matriz[1, 1] = "X";
        matriz[1, 4] = "X";

        matriz[2, 2] = "X";
        matriz[2, 3] = "X";

        matriz[3, 2] = "X";
        matriz[3, 3] = "X";

        matriz[4, 1] = "X";
        matriz[4, 4] = "X";

        for (int i = 0; i < filas; i++)
        {
            for (int j = 0; j < columnas; j++)
            {
            if (matriz[i, j] == "X")
                Console.ForegroundColor = ConsoleColor.Green; 
            else
                Console.ResetColor();
                Console.Write(matriz[i, j] + " ");
            }
            Console.WriteLine();
        }
    }
}
